# CasseoHair — Railway Production Environment Variables
# Copy these into Railway → Your Service → Variables

# =============================================================================
# REQUIRED — App will not work correctly without these
# =============================================================================

# Django secret key — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# Must be False in production
DEBUG=False

# Comma-separated allowed hosts (Railway domain is auto-added via RAILWAY_PUBLIC_DOMAIN)
ALLOWED_HOSTS=.railway.app

# Django settings module (set on Railway service)
DJANGO_SETTINGS_MODULE=config.settings.production

# PostgreSQL — Railway auto-injects this when you add PostgreSQL and link it to your service
# Do NOT set manually if using Railway PostgreSQL plugin
DATABASE_URL=

# Your live Railway URL (replace after first deploy with your actual domain)
SITE_URL=https://your-app-name.up.railway.app
FRONTEND_URL=https://your-app-name.up.railway.app

# CORS — must match your live domain
CORS_ALLOWED_ORIGINS=https://your-app-name.up.railway.app

# CSRF — must match your live domain (required for Django Admin login)
CSRF_TRUSTED_ORIGINS=https://your-app-name.up.railway.app

# =============================================================================
# COMMERCE
# =============================================================================

SITE_NAME=CasseoHair
DELIVERY_FEE=4000
CURRENCY=NGN

# =============================================================================
# PAYMENTS — Required for checkout to work
# =============================================================================

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=

# =============================================================================
# EMAIL — Required for order confirmations (Resend)
# =============================================================================

RESEND_API_KEY=
DEFAULT_FROM_EMAIL=orders@casseohair.com
ADMIN_EMAIL=admin@casseohair.com

# =============================================================================
# MEDIA — Required for product image uploads (Cloudinary)
# =============================================================================

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =============================================================================
# OPTIONAL — First deploy only
# =============================================================================

# Set to "true" ONCE on first deploy to create admin user + sample data, then remove
RUN_SEED=true

# Gunicorn workers (default: 3)
WEB_CONCURRENCY=3
