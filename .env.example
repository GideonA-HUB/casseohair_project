# CasseoHair — Railway Production Environment Variables
# Copy these into Railway → Your Service → Variables

# =============================================================================
# REQUIRED — App will not work correctly without these
# =============================================================================

# Django secret key — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# Must be False in production
DEBUG=False

# Comma-separated allowed hosts (.railway.app matches all Railway subdomains)
ALLOWED_HOSTS=.railway.app,casseohairproject-production.up.railway.app

# Django settings module (set on Railway service)
DJANGO_SETTINGS_MODULE=config.settings.production

# PostgreSQL — Railway auto-injects this when you add PostgreSQL and link it to your service
# Do NOT set manually if using Railway PostgreSQL plugin
DATABASE_URL=

# Your live Railway URL (replace after first deploy with your actual domain)
SITE_URL=https://your-app-name.up.railway.app
FRONTEND_URL=https://your-app-name.up.railway.app

# CORS — must match your live domain
CORS_ALLOWED_ORIGINS=https://your-app-name.up.railway.app

# CSRF — must match your live domain (required for Django Admin login)
CSRF_TRUSTED_ORIGINS=https://your-app-name.up.railway.app

# =============================================================================
# COMMERCE
# =============================================================================

SITE_NAME=CasseoHair
DELIVERY_FEE=4000
CURRENCY=NGN

# =============================================================================
# PAYMENTS — Required for checkout to work (both gateways supported)
# =============================================================================

# Paystack Live keys from Dashboard → Settings → API Keys & Webhooks
# Public: pk_live_...  Secret: sk_live_... (click the eye icon to reveal)
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Flutterwave Live keys from Flutterwave Dashboard → Settings → API Keys
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=

# Also set FRONTEND_URL to your live storefront (used for payment callbacks), e.g.:
# FRONTEND_URL=https://www.casseohair.com

# =============================================================================
# EMAIL — Resend API (verified domain required for sending)
# =============================================================================

RESEND_API_KEY=
# Must use your verified Resend domain, NOT gmail:
DEFAULT_FROM_EMAIL=CasseoHair <orders@casseohair.com>
# Owner inbox for order/contact notifications:
ADMIN_EMAIL=casseohair@gmail.com

# =============================================================================
# MEDIA — Required for product image uploads (Cloudinary)
# =============================================================================

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =============================================================================
# ADMIN — Owner dashboard + Django admin (synced on every deploy)
# =============================================================================

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password
ADMIN_USER_EMAIL=admin@casseohair.com

# Set to "true" ONCE on first deploy to seed sample data, then remove
RUN_SEED=false

# Gunicorn workers (default: 3)
WEB_CONCURRENCY=3
