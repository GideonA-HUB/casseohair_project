# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app
DJANGO_SETTINGS_MODULE=config.settings.production

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/casseohair

# CORS
CORS_ALLOWED_ORIGINS=https://your-domain.railway.app
FRONTEND_URL=https://your-domain.railway.app

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Flutterwave
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=

# Resend
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=orders@casseohair.com
ADMIN_EMAIL=admin@casseohair.com

# Site
SITE_NAME=CasseoHair
SITE_URL=https://your-domain.railway.app
DELIVERY_FEE=4000
CURRENCY=NGN

# Admin JWT
JWT_SECRET_KEY=your-jwt-secret

# Rate Limiting
RATELIMIT_ENABLE=True
